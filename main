            margin-bottom: 15px;
            border-left: 4px solid var(--accent-color);
            padding-left: 10px;
        }

        .box {
            background: var(--card-bg);
            padding: 18px;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        /* 表单元素优化 */
        label {
            display: block;
            margin-top: 15px;
            font-weight: bold;
            font-size: 0.9rem;
            color: #666;
        }

        input, select {
            box-sizing: border-box;
            padding: 12px;
            margin-top: 6px;
            width: 100%;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px; /* 防止iOS缩放 */
            background-color: #fafafa;
        }

        input:focus {
            border-color: var(--accent-color);
            outline: none;
            background-color: #fff;
