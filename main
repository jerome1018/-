<body>

<h1>🎱 北航大师台球积分赛</h1>

<div class="box">
    <h2>新增对局</h2>

    <label>玩法</label>
    <select id="mode" onchange="updateMode()">
        <option value="中八">中八</option>
        <option value="追分">追分</option>
    </select>

    <label>盘口（让球信息）</label>
    <input id="handicap" placeholder="例如：A让B 后2" />

    <div id="scoreLabelSection">
        <label id="scoreLabel">比分（中八）</label>
        <input id="score" placeholder="例如：11:7" />
    </div>

    <h3>玩家信息</h3>
    <div id="players"></div>

    <button onclick="addPlayer()">➕ 添加玩家</button>
    <button onclick="saveRecord()">💾 保存记录</button>
</div>

<div class="box">
    <h2>最近记录</h2>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>玩法/时间</th>
                    <th>盘口/结果</th>
                    <th>详情 (金额)</th>
                </tr>
            </thead>
            <tbody id="recent"></tbody>
        </table>
    </div>
</div>

<div class="box">
    <h2>总奖金榜</h2>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>姓名</th>
                    <th>总奖金</th>
                </tr>
            </thead>
            <tbody id="ranking"></tbody>
        </table>
    </div>
</div>

<script>
// 保持逻辑完全一致
let records = JSON.parse(localStorage.getItem('records') || '[]')

function addPlayer() {
    const mode = document.getElementById('mode').value
    const div = document.createElement('div')
    div.className = 'player'

    div.innerHTML = `
        <button class="remove-btn" onclick="this.parentNode.remove()">✕</button>

        <label>姓名</label>
        <input class="name" placeholder="输入选手姓名" />

        <label>本场金额</label>
        <input class="money" type="number" placeholder="+ / - 金额" />

        ${mode === '追分' ? `
        <label class="pointLabel">追分分值</label>
        <input class="point" type="number" placeholder="+15 / -10" />` : ''}
    `
    document.getElementById('players').appendChild(div)
}

function updateMode() {
    const mode = document.getElementById('mode').value
    document.getElementById('scoreLabelSection').style.display =
        mode === '中八' ? 'block' : 'none'

    const players = document.getElementById('players')
    const names = [...players.querySelectorAll('.name')].map(i => i.value)
    const money = [...players.querySelectorAll('.money')].map(i => i.value)
    const points = [...players.querySelectorAll('.point')].map(i => i.value)

    players.innerHTML = ''
    names.forEach((n, i) => {
        addPlayer()
        const p = players.lastChild
        p.querySelector('.name').value = n
        p.querySelector('.money').value = money[i]
        if (mode === '追分' && p.querySelector('.point')) {
            p.querySelector('.point').value = points[i] || ''
        }
    })
}

function saveRecord() {
    const mode = document.getElementById('mode').value
    const handicap = document.getElementById('handicap').value
    const score = document.getElementById('score').value

    const names = [...document.querySelectorAll('.name')].map(i => i.value.trim())
    const money = [...document.querySelectorAll('.money')].map(i => Number(i.value))
    const points = [...document.querySelectorAll('.point')].map(i => Number(i.value || 0))

    if (names.length < 2 || names.length > 3) {
        alert('只能 2 或 3 人')
        return
    }

    if (names.some(n => !n)) {
        alert('姓名不能为空')
        return
    }

    if (money.some(m => isNaN(m))) {
        alert('金额必须填写')
        return
    }

    if (mode === '追分') {
        const sum = points.reduce((a, b) => a + b, 0)
        if (sum !== 0) {
            alert('追分分值总和必须为 0')
            return
        }
    }

    records.unshift({
        time: new Date().toLocaleString('zh-CN', {month:'numeric', day:'numeric', hour:'2-digit', minute:'2-digit'}),
        mode,
        handicap,
        result: mode === '中八' ? score : points.join(','),
        players: names,
        money
    })

    localStorage.setItem('records', JSON.stringify(records))
    location.reload()
}

function render() {
    const recent = document.getElementById('recent')
    const ranking = {}

    records.slice(0, 15).forEach(r => {
        const tr = document.createElement('tr')
        // 手机端合并显示一些字段以节省空间
        tr.innerHTML = `
            <td><strong>${r.mode}</strong><br><small style="color:#999">${r.time}</small></td>
            <td><small>${r.handicap || '-'}</small><br><strong>${r.result}</strong></td>
            <td>${r.players.map((p, i) => `${p}(${r.money[i]})`).join('<br>')}</td>
        `
        recent.appendChild(tr)

        r.players.forEach((p, i) => {
            ranking[p] = (ranking[p] || 0) + r.money[i]
        })
    })

    const rankBody = document.getElementById('ranking')
    Object.entries(ranking)
        .sort((a, b) => b[1] - a[1])
        .forEach(([name, total]) => {
            const tr = document.createElement('tr')
            const color = total >= 0 ? '#e67e22' : '#27ae60';
            tr.innerHTML = `<td>${name}</td><td style="color:${color}">${total > 0 ? '+' + total : total}</td>`
            rankBody.appendChild(tr)
        })
}

render()
updateMode()
</script>

</body>
</html>
